<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ 'page.dashboard'|trans({}, 'NowoWorkflowBundle') }}{% endblock %} · {{ 'title_suffix'|trans({}, 'NowoWorkflowBundle') }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
        .collection-item { border: 1px dashed var(--bs-border-color); border-radius: var(--bs-border-radius); }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="{{ path('nowo_workflow_dashboard') }}">{{ 'brand'|trans({}, 'NowoWorkflowBundle') }}</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#workflowNav" aria-controls="workflowNav" aria-expanded="false" aria-label="{{ 'nav.toggle'|trans({}, 'NowoWorkflowBundle') }}">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="workflowNav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('nowo_workflow_dashboard') }}">{{ 'nav.dashboard'|trans({}, 'NowoWorkflowBundle') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('nowo_workflow_definition_index') }}">{{ 'nav.definitions'|trans({}, 'NowoWorkflowBundle') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('nowo_workflow_definition_new') }}">{{ 'nav.new_definition'|trans({}, 'NowoWorkflowBundle') }}</a>
                    </li>
                    {% include '@NowoWorkflowBundle/_locale_switcher.html.twig' %}
                </ul>
            </div>
        </div>
    </nav>

    <main class="container pb-5">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message|trans({}, 'NowoWorkflowBundle') }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'action.close'|trans({}, 'NowoWorkflowBundle') }}"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
