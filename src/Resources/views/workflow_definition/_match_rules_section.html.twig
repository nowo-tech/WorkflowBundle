{% set collection = form.matchRules %}

<div
    class="workflow-collection"
    data-collection-key="matchRules"
    data-form-prefix="{{ collection.vars.full_name }}"
    data-prototype="{{ form_widget(collection.vars.prototype)|e('html_attr') }}"
    data-index="{{ collection|length }}"
    data-modal-id="match-rule-editor-modal"
>
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <p class="text-muted small mb-0">{{ 'form.help.match_rules_list'|trans({}, 'nowo_workflow') }}</p>
        <button type="button" class="btn btn-sm btn-primary" data-collection-add>
            {{ 'action.add_match_rule'|trans({}, 'nowo_workflow') }}
        </button>
    </div>

    <div class="table-responsive border rounded bg-white">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>{{ 'form.field.parameter_key'|trans({}, 'nowo_workflow') }}</th>
                    <th>{{ 'form.field.parameter_value'|trans({}, 'nowo_workflow') }}</th>
                    <th>{{ 'form.field.order'|trans({}, 'nowo_workflow') }}</th>
                    <th class="text-end">{{ 'table.actions'|trans({}, 'nowo_workflow') }}</th>
                </tr>
            </thead>
            <tbody data-collection-table></tbody>
        </table>
        <p class="text-muted text-center py-4 mb-0 d-none" data-collection-empty>{{ 'collection.no_match_rules'|trans({}, 'nowo_workflow') }}</p>
    </div>

    <div class="d-none" data-collection-entries>
        {% for ruleForm in collection %}
            <div data-collection-entry="{{ loop.index0 }}">{{ form_widget(ruleForm) }}</div>
        {% endfor %}
    </div>
</div>

<div class="modal fade" id="match-rule-editor-modal" tabindex="-1" aria-labelledby="match-rule-editor-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="match-rule-editor-modal-label" data-modal-title-add="{{ 'modal.add_match_rule'|trans({}, 'nowo_workflow') }}" data-modal-title-edit="{{ 'modal.edit_match_rule'|trans({}, 'nowo_workflow') }}"></h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'action.close'|trans({}, 'nowo_workflow') }}"></button>
            </div>
            <div class="modal-body" data-modal-body></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-modal-cancel>{{ 'action.cancel'|trans({}, 'nowo_workflow') }}</button>
                <button type="button" class="btn btn-primary" data-modal-apply>{{ 'action.apply'|trans({}, 'nowo_workflow') }}</button>
            </div>
        </div>
    </div>
</div>
