{% set collection = form.places %}

<div
    class="workflow-collection"
    data-collection-key="places"
    data-form-prefix="{{ collection.vars.full_name }}"
    data-prototype="{{ form_widget(collection.vars.prototype)|e('html_attr') }}"
    data-index="{{ collection|length }}"
    data-modal-id="place-editor-modal"
    data-place-names="[]"
>
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <p class="text-muted small mb-0">{{ 'form.help.places_list'|trans({}, 'NowoWorkflowBundle') }}</p>
        <button type="button" class="btn btn-sm btn-primary" data-collection-add>
            {{ 'action.add_place'|trans({}, 'NowoWorkflowBundle') }}
        </button>
    </div>

    <div class="table-responsive border rounded bg-white">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>{{ 'table.name'|trans({}, 'NowoWorkflowBundle') }}</th>
                    <th>{{ 'form.field.label'|trans({}, 'NowoWorkflowBundle') }}</th>
                    <th>{{ 'form.field.order'|trans({}, 'NowoWorkflowBundle') }}</th>
                    <th class="text-end">{{ 'table.actions'|trans({}, 'NowoWorkflowBundle') }}</th>
                </tr>
            </thead>
            <tbody data-collection-table></tbody>
        </table>
        <p class="text-muted text-center py-4 mb-0 d-none" data-collection-empty>{{ 'collection.no_places'|trans({}, 'NowoWorkflowBundle') }}</p>
    </div>

    <div class="d-none" data-collection-entries>
        {% for placeForm in collection %}
            <div data-collection-entry="{{ loop.index0 }}">{{ form_widget(placeForm) }}</div>
        {% endfor %}
    </div>
</div>

<div class="modal fade" id="place-editor-modal" tabindex="-1" aria-labelledby="place-editor-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="place-editor-modal-label" data-modal-title-add="{{ 'modal.add_place'|trans({}, 'NowoWorkflowBundle') }}" data-modal-title-edit="{{ 'modal.edit_place'|trans({}, 'NowoWorkflowBundle') }}"></h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'action.close'|trans({}, 'NowoWorkflowBundle') }}"></button>
            </div>
            <div class="modal-body" data-modal-body></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-modal-cancel>{{ 'action.cancel'|trans({}, 'NowoWorkflowBundle') }}</button>
                <button type="button" class="btn btn-primary" data-modal-apply>{{ 'action.apply'|trans({}, 'NowoWorkflowBundle') }}</button>
            </div>
        </div>
    </div>
</div>
