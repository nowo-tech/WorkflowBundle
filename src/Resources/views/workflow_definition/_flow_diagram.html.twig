{# @var graph array #}
<div class="card shadow-sm mb-4">
    <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div>
            <h2 class="h5 mb-0">{{ 'diagram.title'|trans({}, 'NowoWorkflowBundle') }}</h2>
            <small class="text-muted">{{ 'diagram.hint'|trans({}, 'NowoWorkflowBundle') }}</small>
        </div>
        <span class="badge text-bg-secondary">{{ ('workflow_type.' ~ graph.type)|trans({}, 'NowoWorkflowBundle') }}</span>
    </div>
    <div class="card-body">
        <div class="workflow-diagram-viewport">
            {% if graph.layout.sequence %}
                <div class="workflow-diagram-linear">
                    {% for item in graph.layout.sequence %}
                        {% if item.type == 'place' %}
                            {% set place = item.place %}
                            <button
                                type="button"
                                class="workflow-state-node{% if place.isInitial %} workflow-state-node--initial{% endif %}"
                                data-bs-toggle="modal"
                                data-bs-target="#place-modal-{{ place.index }}"
                            >
                                <span class="workflow-state-node__title">{{ place.displayLabel }}</span>
                                <span class="workflow-state-node__name"><code>{{ place.name }}</code></span>
                            </button>
                        {% else %}
                            <div class="workflow-diagram-link" aria-hidden="true">
                                <button
                                    type="button"
                                    class="workflow-transition-pill"
                                    data-bs-toggle="modal"
                                    data-bs-target="#transition-modal-{{ item.transitionIndex }}"
                                >
                                    {{ item.transitionLabel }}
                                </button>
                                <span class="workflow-diagram-link-line"></span>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            {% else %}
                <div class="workflow-diagram-grid">
                    {% for column in graph.layout.columns %}
                        {% if not loop.first %}
                            <div class="workflow-diagram-bridge">
                                {% set bridgeEdges = graph.layout.bridges[column.index - 1]|default([]) %}
                                {% if bridgeEdges is empty %}
                                    <div class="workflow-diagram-bridge-spacer"></div>
                                {% else %}
                                    {% for edge in bridgeEdges %}
                                        <div class="workflow-diagram-bridge-item">
                                            <button
                                                type="button"
                                                class="workflow-transition-pill"
                                                data-bs-toggle="modal"
                                                data-bs-target="#transition-modal-{{ edge.transitionIndex }}"
                                            >
                                                {{ edge.transitionLabel }}
                                            </button>
                                            <span class="workflow-diagram-link-line"></span>
                                        </div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                        {% endif %}

                        <div class="workflow-diagram-column">
                            {% for place in column.places %}
                                <button
                                    type="button"
                                    class="workflow-state-node{% if place.isInitial %} workflow-state-node--initial{% endif %}"
                                    data-bs-toggle="modal"
                                    data-bs-target="#place-modal-{{ place.index }}"
                                >
                                    <span class="workflow-state-node__title">{{ place.displayLabel }}</span>
                                    <span class="workflow-state-node__name"><code>{{ place.name }}</code></span>
                                </button>
                            {% endfor %}
                        </div>
                    {% endfor %}
                </div>

                {% if graph.layout.backEdges %}
                    <div class="workflow-diagram-back-edges mt-4 pt-3 border-top">
                        <div class="small text-muted mb-2">{{ 'diagram.back_edges'|trans({}, 'NowoWorkflowBundle') }}</div>
                        <div class="d-flex flex-wrap gap-2">
                            {% for edge in graph.layout.backEdges %}
                                <button
                                    type="button"
                                    class="btn btn-sm btn-outline-secondary workflow-back-edge"
                                    data-bs-toggle="modal"
                                    data-bs-target="#transition-modal-{{ edge.transitionIndex }}"
                                >
                                    <code>{{ edge.fromPlace }}</code>
                                    <span class="mx-1">→</span>
                                    {{ edge.transitionLabel }}
                                    <span class="mx-1">→</span>
                                    <code>{{ edge.toPlace }}</code>
                                </button>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            {% endif %}
        </div>

        <div class="d-flex flex-wrap gap-3 small text-muted mt-3 pt-3 border-top">
            <span><span class="workflow-flow-legend-dot workflow-flow-legend-dot--initial"></span> {{ 'diagram.legend.initial'|trans({}, 'NowoWorkflowBundle') }}</span>
            <span><span class="workflow-flow-legend-dot workflow-flow-legend-dot--place"></span> {{ 'diagram.legend.place'|trans({}, 'NowoWorkflowBundle') }}</span>
            <span><span class="workflow-flow-legend-dot workflow-flow-legend-dot--transition"></span> {{ 'diagram.legend.transition'|trans({}, 'NowoWorkflowBundle') }}</span>
        </div>
    </div>
</div>

{% for place in graph.places %}
    <div class="modal fade" id="place-modal-{{ loop.index0 }}" tabindex="-1" aria-labelledby="place-modal-label-{{ loop.index0 }}" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title h5" id="place-modal-label-{{ loop.index0 }}">
                        {{ place.displayLabel }}
                        {% if place.isInitial %}<span class="badge text-bg-success ms-2">{{ 'status.initial'|trans({}, 'NowoWorkflowBundle') }}</span>{% endif %}
                    </h3>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'action.close'|trans({}, 'NowoWorkflowBundle') }}"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">{{ 'diagram.modal.name'|trans({}, 'NowoWorkflowBundle') }}</dt>
                        <dd class="col-sm-8"><code>{{ place.name }}</code></dd>
                        {% if place.label %}
                            <dt class="col-sm-4">{{ 'diagram.modal.label'|trans({}, 'NowoWorkflowBundle') }}</dt>
                            <dd class="col-sm-8">{{ place.label }}</dd>
                        {% endif %}
                        <dt class="col-sm-4">{{ 'diagram.modal.sort_order'|trans({}, 'NowoWorkflowBundle') }}</dt>
                        <dd class="col-sm-8">{{ place.sortOrder }}</dd>
                    </dl>

                    {% if place.incoming %}
                        <hr>
                        <h4 class="h6">{{ 'diagram.modal.incoming'|trans({}, 'NowoWorkflowBundle') }}</h4>
                        <ul class="list-group list-group-flush mb-0">
                            {% for transition in place.incoming %}
                                <li class="list-group-item px-0">
                                    <button type="button" class="btn btn-link p-0 align-baseline workflow-open-transition" data-transition-index="{{ transition.transitionIndex }}">
                                        {{ transition.transitionLabel }}
                                    </button>
                                    <span class="text-muted small">{{ 'diagram.transition_from'|trans({}, 'NowoWorkflowBundle') }} {% for from in transition.fromPlaces %}<code>{{ from }}</code>{% if not loop.last %}, {% endif %}{% endfor %}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}

                    {% if place.outgoing %}
                        <hr>
                        <h4 class="h6">{{ 'diagram.modal.outgoing'|trans({}, 'NowoWorkflowBundle') }}</h4>
                        <ul class="list-group list-group-flush mb-0">
                            {% for transition in place.outgoing %}
                                <li class="list-group-item px-0">
                                    <button type="button" class="btn btn-link p-0 align-baseline workflow-open-transition" data-transition-index="{{ transition.transitionIndex }}">
                                        {{ transition.transitionLabel }}
                                    </button>
                                    <span class="text-muted small">{{ 'diagram.transition_to'|trans({}, 'NowoWorkflowBundle') }} {% for to in transition.toPlaces %}<code>{{ to }}</code>{% if not loop.last %}, {% endif %}{% endfor %}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}

                    {% if place.incoming is empty and place.outgoing is empty %}
                        <p class="text-muted mb-0 mt-3">{{ 'diagram.modal.no_transitions'|trans({}, 'NowoWorkflowBundle') }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endfor %}

{% for transition in graph.transitions %}
    <div class="modal fade" id="transition-modal-{{ loop.index0 }}" tabindex="-1" aria-labelledby="transition-modal-label-{{ loop.index0 }}" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title h5" id="transition-modal-label-{{ loop.index0 }}">{{ transition.displayLabel }}</h3>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'action.close'|trans({}, 'NowoWorkflowBundle') }}"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-3">
                        <dt class="col-sm-4">{{ 'diagram.modal.name'|trans({}, 'NowoWorkflowBundle') }}</dt>
                        <dd class="col-sm-8"><code>{{ transition.name }}</code></dd>
                        {% if transition.label %}
                            <dt class="col-sm-4">{{ 'diagram.modal.label'|trans({}, 'NowoWorkflowBundle') }}</dt>
                            <dd class="col-sm-8">{{ transition.label }}</dd>
                        {% endif %}
                    </dl>

                    <div class="d-flex align-items-center flex-wrap gap-2">
                        <div class="flex-grow-1">
                            <div class="text-muted small mb-1">{{ 'diagram.modal.from'|trans({}, 'NowoWorkflowBundle') }}</div>
                            <div>
                                {% for from in transition.fromPlaces %}
                                    <span class="badge text-bg-light border"><code>{{ from }}</code></span>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="text-primary fs-4 px-2">→</div>
                        <div class="flex-grow-1">
                            <div class="text-muted small mb-1">{{ 'diagram.modal.to'|trans({}, 'NowoWorkflowBundle') }}</div>
                            <div>
                                {% for to in transition.toPlaces %}
                                    <span class="badge text-bg-light border"><code>{{ to }}</code></span>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <p class="text-muted small mt-3 mb-0">
                        {% if graph.type == 'state_machine' %}
                            {{ 'diagram.modal.state_machine_help'|trans({}, 'NowoWorkflowBundle') }}
                        {% else %}
                            {{ 'diagram.modal.workflow_help'|trans({}, 'NowoWorkflowBundle') }}
                        {% endif %}
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endfor %}

<style>
    .workflow-diagram-viewport {
        overflow-x: auto;
        padding: 0.5rem;
    }

    .workflow-diagram-linear,
    .workflow-diagram-grid {
        display: flex;
        align-items: center;
        gap: 0;
        min-width: max-content;
    }

    .workflow-diagram-column {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1rem;
    }

    .workflow-diagram-bridge {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1rem;
        min-width: 7.5rem;
        padding: 0 0.35rem;
    }

    .workflow-diagram-bridge-item,
    .workflow-diagram-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.35rem;
        min-width: 7.5rem;
    }

    .workflow-diagram-bridge-spacer {
        width: 7.5rem;
        height: 1px;
    }

    .workflow-state-node {
        width: 10.5rem;
        min-height: 4.75rem;
        border: 2px solid var(--bs-primary);
        border-radius: 0.75rem;
        background: #fff;
        box-shadow: 0 0.25rem 0.75rem rgba(15, 23, 42, 0.08);
        padding: 0.75rem;
        text-align: center;
        cursor: pointer;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .workflow-state-node:hover,
    .workflow-state-node:focus-visible {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(15, 23, 42, 0.12);
        outline: none;
    }

    .workflow-state-node--initial {
        border-color: var(--bs-success);
        background: #f0fdf4;
    }

    .workflow-state-node__title {
        display: block;
        font-weight: 600;
        font-size: 0.95rem;
        line-height: 1.2;
        margin-bottom: 0.25rem;
        word-break: break-word;
    }

    .workflow-state-node__name {
        display: block;
        font-size: 0.75rem;
        color: var(--bs-secondary-color);
    }

    .workflow-transition-pill {
        border: 1px solid #cbd5e1;
        background: #fff;
        color: #334155;
        border-radius: 999px;
        padding: 0.25rem 0.75rem;
        font-size: 0.8rem;
        line-height: 1.2;
        white-space: nowrap;
        cursor: pointer;
        transition: background-color 0.15s ease, border-color 0.15s ease;
    }

    .workflow-transition-pill:hover,
    .workflow-transition-pill:focus-visible {
        background: #f8fafc;
        border-color: #94a3b8;
        outline: none;
    }

    .workflow-diagram-link-line {
        display: block;
        width: 100%;
        height: 2px;
        background: #64748b;
        position: relative;
    }

    .workflow-diagram-link-line::after {
        content: '';
        position: absolute;
        right: -1px;
        top: 50%;
        width: 0.45rem;
        height: 0.45rem;
        border-right: 2px solid #64748b;
        border-bottom: 2px solid #64748b;
        transform: translateY(-50%) rotate(-45deg);
    }

    .workflow-flow-legend-dot {
        display: inline-block;
        width: 0.75rem;
        height: 0.75rem;
        border-radius: 999px;
        margin-right: 0.25rem;
        vertical-align: -1px;
    }

    .workflow-flow-legend-dot--initial {
        background: #f0fdf4;
        border: 2px solid var(--bs-success);
    }

    .workflow-flow-legend-dot--place {
        background: #fff;
        border: 2px solid var(--bs-primary);
    }

    .workflow-flow-legend-dot--transition {
        background: #fff;
        border: 2px solid #94a3b8;
        border-radius: 0.25rem;
    }
</style>

<script>
document.querySelectorAll('.workflow-open-transition').forEach((button) => {
    button.addEventListener('click', () => {
        const transitionIndex = button.dataset.transitionIndex;
        const placeModal = button.closest('.modal.show');
        if (placeModal) {
            bootstrap.Modal.getInstance(placeModal)?.hide();
        }
        bootstrap.Modal.getOrCreateInstance(document.getElementById('transition-modal-' + transitionIndex)).show();
    });
});
</script>
