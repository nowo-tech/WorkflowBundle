{% extends '@NowoWorkflowBundle/layout.html.twig' %}

{% block title %}{{ 'page.dashboard'|trans({}, 'NowoWorkflowBundle') }}{% endblock %}

{% block body %}
    <div class="mb-4">
        <h1 class="h2 mb-2">{{ 'dashboard.title'|trans({}, 'NowoWorkflowBundle') }}</h1>
        <p class="text-muted mb-0">{{ 'dashboard.intro'|trans({'%class%': '<code>DatabaseWorkflowRegistry</code>'}, 'NowoWorkflowBundle')|raw }}</p>
    </div>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">{{ 'dashboard.definitions'|trans({}, 'NowoWorkflowBundle') }}</h2>
            <a class="btn btn-sm btn-primary" href="{{ path('nowo_workflow_definition_new') }}">{{ 'nav.new_definition'|trans({}, 'NowoWorkflowBundle') }}</a>
        </div>
        <div class="card-body">
            {% if definitions is empty %}
                <p class="text-muted mb-0">
                    {{ 'dashboard.empty_prefix'|trans({}, 'NowoWorkflowBundle') }}
                    <a href="{{ path('nowo_workflow_definition_new') }}">{{ 'action.create_one'|trans({}, 'NowoWorkflowBundle') }}</a>
                    {{ 'dashboard.empty_suffix'|trans({}, 'NowoWorkflowBundle') }}
                    <code>php bin/console nowo:workflow:seed-demo</code>.
                </p>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>{{ 'table.name'|trans({}, 'NowoWorkflowBundle') }}</th>
                                <th>{{ 'table.slug'|trans({}, 'NowoWorkflowBundle') }}</th>
                                <th>{{ 'table.type'|trans({}, 'NowoWorkflowBundle') }}</th>
                                <th>{{ 'table.subject'|trans({}, 'NowoWorkflowBundle') }}</th>
                                <th>{{ 'table.status'|trans({}, 'NowoWorkflowBundle') }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for definition in definitions %}
                                <tr>
                                    <td class="fw-semibold">{{ definition.name }}</td>
                                    <td><code>{{ definition.slug }}</code></td>
                                    <td>{{ ('workflow_type.' ~ definition.type.value)|trans({}, 'NowoWorkflowBundle') }}</td>
                                    <td><code class="small">{{ definition.subjectClass }}</code></td>
                                    <td>
                                        {% if definition.enabled %}
                                            <span class="badge text-bg-success">{{ 'status.enabled'|trans({}, 'NowoWorkflowBundle') }}</span>
                                        {% else %}
                                            <span class="badge text-bg-secondary">{{ 'status.disabled'|trans({}, 'NowoWorkflowBundle') }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary" href="{{ path('nowo_workflow_definition_show', {id: definition.id}) }}">{{ 'action.view'|trans({}, 'NowoWorkflowBundle') }}</a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
