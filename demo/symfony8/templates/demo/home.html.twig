{% extends 'base.html.twig' %}

{% block title %}{{ 'title'|trans({}, 'demo') }}{% endblock %}

{% block body %}
    <div class="mb-4">
        <h1 class="display-6 mb-2">{{ 'title'|trans({}, 'demo') }} <span class="badge text-bg-primary">{{ version_badge }}</span></h1>
        <p class="lead text-muted">{{ 'lead'|trans({}, 'demo') }}</p>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="card h-100 shadow-sm border-warning">
                <div class="card-body d-flex flex-column flex-lg-row align-items-lg-center gap-3">
                    <div class="flex-grow-1">
                        <h2 class="h5 card-title mb-2">{{ 'home.branching.title'|trans({}, 'demo') }}</h2>
                        <p class="card-text text-muted mb-0">{{ 'home.branching.text'|trans({'%entity%': 'DemoChangeRequest'}, 'demo') }}</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-warning" href="{{ path('demo_change_requests') }}">{{ 'home.branching.playground'|trans({}, 'demo') }}</a>
                        <a class="btn btn-outline-primary" href="{{ path('nowo_workflow_definition_show_by_slug', {slug: 'change_request_review'}) }}">{{ 'home.branching.diagram'|trans({}, 'demo') }}</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5 card-title">{{ 'home.resolver.title'|trans({}, 'demo') }}</h2>
                    <p class="card-text text-muted flex-grow-1">{{ 'home.resolver.text'|trans({}, 'demo') }}</p>
                    <a class="btn btn-primary" href="{{ path('demo_resolver') }}">{{ 'home.resolver.action'|trans({}, 'demo') }}</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5 card-title">{{ 'home.orders.title'|trans({}, 'demo') }}</h2>
                    <p class="card-text text-muted flex-grow-1">{{ 'home.orders.text'|trans({'%entity%': 'DemoOrder'}, 'demo') }}</p>
                    <a class="btn btn-primary" href="{{ path('demo_orders') }}">{{ 'home.orders.action'|trans({}, 'demo') }}</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5 card-title">{{ 'home.documents.title'|trans({}, 'demo') }}</h2>
                    <p class="card-text text-muted flex-grow-1">{{ 'home.documents.text'|trans({'%entity%': 'DemoDocument'}, 'demo') }}</p>
                    <a class="btn btn-primary" href="{{ path('demo_documents') }}">{{ 'home.documents.action'|trans({}, 'demo') }}</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5 card-title">{{ 'home.expenses.title'|trans({}, 'demo') }}</h2>
                    <p class="card-text text-muted flex-grow-1">{{ 'home.expenses.text'|trans({'%entity%': 'DemoExpense'}, 'demo') }}</p>
                    <a class="btn btn-primary" href="{{ path('demo_expenses') }}">{{ 'home.expenses.action'|trans({}, 'demo') }}</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5 card-title">{{ 'home.purchase_orders.title'|trans({}, 'demo') }}</h2>
                    <p class="card-text text-muted flex-grow-1">{{ 'home.purchase_orders.text'|trans({'%entity%': 'DemoPurchaseOrder'}, 'demo') }}</p>
                    <a class="btn btn-primary" href="{{ path('demo_purchase_orders') }}">{{ 'home.purchase_orders.action'|trans({}, 'demo') }}</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5 card-title">{{ 'home.crud.title'|trans({}, 'demo') }}</h2>
                    <p class="card-text text-muted flex-grow-1">{{ 'home.crud.text'|trans({}, 'demo') }}</p>
                    <a class="btn btn-outline-primary" href="{{ path('nowo_workflow_dashboard') }}">{{ 'home.crud.action'|trans({}, 'demo') }}</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
