<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ 'title'|trans({}, 'demo') }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="{{ path('demo_home') }}">{{ 'brand'|trans({}, 'demo') }}</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#demoNav" aria-controls="demoNav" aria-expanded="false" aria-label="{{ 'nav.toggle'|trans({}, 'demo') }}">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="demoNav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item"><a class="nav-link" href="{{ path('demo_home') }}">{{ 'nav.home'|trans({}, 'demo') }}</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('demo_resolver') }}">{{ 'nav.resolver'|trans({}, 'demo') }}</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('nowo_workflow_dashboard') }}">{{ 'nav.crud'|trans({}, 'demo') }}</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('demo_change_requests') }}">{{ 'nav.change_requests'|trans({}, 'demo') }}</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('demo_orders') }}">{{ 'nav.orders'|trans({}, 'demo') }}</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('demo_documents') }}">{{ 'nav.documents'|trans({}, 'demo') }}</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('demo_expenses') }}">{{ 'nav.expenses'|trans({}, 'demo') }}</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('demo_purchase_orders') }}">{{ 'nav.purchase_orders'|trans({}, 'demo') }}</a></li>
                    {% include '@NowoWorkflow/_locale_switcher.html.twig' with {locale_route: 'demo_locale_switch'} %}
                </ul>
            </div>
        </div>
    </nav>

    <main class="container pb-5">
        {% block body %}{% endblock %}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
