# Demo environment template. Copy to .env (e.g. cp .env.example .env) and adjust.
# Do not commit .env or local .env* files.
#
# Inside Docker, docker-compose.yml sets DATABASE_URL to PostgreSQL on host `database`.
# The value below is for reference / CLI outside compose.

APP_ENV=dev
APP_SECRET=change_this_secret_key_to_a_random_value
APP_DEBUG=1

# FRANKENPHP_MODE: FrankenPHP runtime mode — `classic` (one process per request) or `worker` (long-lived workers).
# Default: worker. Set classic for per-request PHP / easier hot-reload. Recreate with `docker compose up -d` after change.
FRANKENPHP_MODE=worker

PORT=8022

TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
DEFAULT_URI=http://localhost

POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=!ChangeMe!
POSTGRES_VERSION=16

DATABASE_URL="postgresql://app:!ChangeMe!@database:5432/app?serverVersion=16&charset=utf8"

# Optional: SQLite without Postgres (local only — not used by docker-compose)
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
